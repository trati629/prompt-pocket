{
  "manifest_version": 3,
  "name": "Universal AI Prompt Templates",
  "version": "1.0.0",
  "description": "Insert, manage and import prompt templates across supported AI web apps",
  "permissions": [
    "sidePanel",
    "storage",
    "activeTab",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://copilot.microsoft.com/*"
  ],
  "side_panel": {
    "default_path": "sidepanel/dormant.html"
  },
  "action": {
    "default_title": "Universal AI Prompt Templates",
    "default_icon": {
      "128": "icons/icon-inactive-128.png"
    }
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://copilot.microsoft.com/*"
      ],
      "js": [
        "content/theme-detector.js",
        "content/injector.js",
        "content/selector-canary.js",
        "content/content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": []
}
